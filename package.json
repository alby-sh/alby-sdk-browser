{
  "name": "@alby/browser",
  "version": "0.1.0",
  "description": "Official Alby error-tracking SDK for browsers",
  "keywords": [
    "alby",
    "error-tracking",
    "monitoring",
    "observability",
    "crash-reporting",
    "browser"
  ],
  "homepage": "https://github.com/alby-sh/alby-browser",
  "license": "MIT",
  "author": "Alby <info@alby.sh>",
  "repository": {
    "type": "git",
    "url": "https://github.com/alby-sh/alby-browser.git"
  },
  "type": "module",
  "main": "./dist/alby.cjs.js",
  "module": "./dist/alby.esm.js",
  "types": "./dist/alby.d.ts",
  "browser": "./dist/alby.iife.js",
  "unpkg": "./dist/alby.iife.js",
  "jsdelivr": "./dist/alby.iife.js",
  "exports": {
    ".": {
      "types": "./dist/alby.d.ts",
      "import": "./dist/alby.esm.js",
      "require": "./dist/alby.cjs.js",
      "browser": "./dist/alby.iife.js",
      "default": "./dist/alby.esm.js"
    }
  },
  "files": [
    "dist",
    "PROTOCOL_V1.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "smoke": "node e2e/smoke.mjs",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^11.1.6",
    "@types/node": "^20.11.0",
    "jsdom": "^24.0.0",
    "rollup": "^4.12.0",
    "rollup-plugin-dts": "^6.1.0",
    "tslib": "^2.6.2",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
